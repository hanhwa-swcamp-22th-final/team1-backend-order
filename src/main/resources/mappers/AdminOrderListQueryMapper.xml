<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  ORD-005 관리자 주문 목록 조회 MyBatis XML Mapper.
  namespace 는 @Mapper 인터페이스 FQCN 과 반드시 일치해야 한다.
-->
<mapper namespace="com.conk.order.query.mapper.AdminOrderListQueryMapper">

    <!--
      공통 WHERE 절.
      ORD-004(SellerOrderListQueryMapper) 와 달리 sellerId 도 <if> 로 감싼다.
      sellerId 가 null 이면 전체 셀러 주문을 조회한다.
    -->
    <sql id="whereClause">
        <where>
            <!-- sellerId 가 있으면 해당 셀러만 필터링한다. -->
            <if test="sellerId != null and sellerId != ''">
                o.seller_id = #{sellerId}
            </if>
            <!-- status 가 있으면 해당 상태만 필터링한다. -->
            <if test="status != null">
                AND o.status = #{status}
            </if>
            <!-- startDate 가 있으면 해당 날짜 이후 주문만 조회한다. -->
            <if test="startDate != null">
                AND DATE(o.ordered_at) &gt;= #{startDate}
            </if>
            <!-- endDate 가 있으면 해당 날짜 이전 주문만 조회한다. -->
            <if test="endDate != null">
                AND DATE(o.ordered_at) &lt;= #{endDate}
            </if>
        </where>
    </sql>

    <!--
      현재 페이지에 해당하는 주문 목록을 조회한다.
      SellerOrderSummary 와 달리 sellerId 컬럼을 추가로 SELECT 한다.
    -->
    <select id="findOrders" resultType="com.conk.order.query.dto.AdminOrderSummary">
        SELECT
            o.order_id         AS orderNo,
            o.ordered_at       AS orderedAt,
            o.status           AS status,
            o.order_channel    AS orderChannel,
            o.seller_id        AS sellerId,
            o.receiver_name    AS receiverName,
            COUNT(i.id)        AS itemCount
        FROM sales_order o
        LEFT JOIN sales_order_item i ON i.order_id = o.order_id
        <include refid="whereClause"/>
        GROUP BY
            o.order_id,
            o.ordered_at,
            o.status,
            o.order_channel,
            o.seller_id,
            o.receiver_name
        ORDER BY o.ordered_at DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!--
      페이징 없이 전체 건수를 조회한다.
      findOrders 와 동일한 whereClause 를 재사용한다.
    -->
    <select id="countOrders" resultType="int">
        SELECT COUNT(*)
        FROM sales_order o
        <include refid="whereClause"/>
    </select>

</mapper>