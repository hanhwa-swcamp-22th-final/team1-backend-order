<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  ORD-004 셀러 주문 목록 조회 MyBatis XML Mapper.
  namespace 는 @Mapper 인터페이스 FQCN 과 반드시 일치해야 한다.
-->
<mapper namespace="com.conk.order.query.mapper.SellerOrderListQueryMapper">

    <!--
      공통 WHERE 절을 <sql> 블록으로 추출한다.
      findOrders / countOrders 두 쿼리가 동일한 필터를 공유하므로
      <include refid="whereClause"/> 로 재사용한다.
    -->
    <sql id="whereClause">
        WHERE o.seller_id = #{sellerId}
        <!--
          seller grouped status 를 raw OrderStatus 목록으로 확장해 IN 조건을 만든다.
          DISPATCHED 처럼 여러 raw 상태를 포함하는 경우를 이곳에서 처리한다.
        -->
        <if test="statuses != null and statuses.size > 0">
            AND o.status IN
            <foreach collection="statuses" item="status" open="(" separator="," close=")">
                #{status}
            </foreach>
        </if>
        <!-- startDate != null 이면 해당 날짜 이후 주문만 조회한다. -->
        <if test="startDate != null">
            AND DATE(o.ordered_at) &gt;= #{startDate}
        </if>
        <!-- endDate != null 이면 해당 날짜 이전 주문만 조회한다. -->
        <if test="endDate != null">
            AND DATE(o.ordered_at) &lt;= #{endDate}
        </if>
    </sql>

    <!--
      현재 페이지에 해당하는 주문 목록을 조회한다.

      resultType = SellerOrderSummary FQCN.
      MyBatis 가 SELECT 컬럼명을 DTO 필드명에 자동 매핑한다.
        order_id      → orderId
        ordered_at    → orderedAt
        raw_status    → rawStatus (String → OrderStatus 자동 변환)
        order_channel → orderChannel
        receiver_name → receiverName
        item_count    → itemCount  (서브쿼리로 계산)
    -->
    <select id="findOrders" resultType="com.conk.order.query.dto.response.SellerOrderSummary">
        SELECT
            o.order_id           AS orderId,
            o.ordered_at         AS orderedAt,
            o.status             AS rawStatus,
            o.order_channel      AS orderChannel,
            o.receiver_name      AS receiverName,
            COUNT(i.id)          AS itemCount,
            o.ship_to_address1   AS street1,
            o.ship_to_address2   AS street2,
            o.ship_to_state      AS state,
            o.ship_to_zip_code   AS zip,
            o.ship_to_country    AS country,
            o.receiver_phone_no  AS phone,
            o.tracking_code      AS trackingNo
        FROM sales_order o
        LEFT JOIN sales_order_item i ON i.order_id = o.order_id
        <include refid="whereClause"/>
        GROUP BY
            o.order_id,
            o.ordered_at,
            o.status,
            o.order_channel,
            o.receiver_name,
            o.ship_to_address1,
            o.ship_to_address2,
            o.ship_to_state,
            o.ship_to_zip_code,
            o.ship_to_country,
            o.receiver_phone_no,
            o.tracking_code
        ORDER BY o.ordered_at DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!--
      페이징 없이 전체 건수를 조회한다.
      프론트에서 totalCount / size 로 총 페이지 수를 계산한다.
      findOrders 와 동일한 whereClause 를 재사용한다.
    -->
    <select id="countOrders" resultType="int">
        SELECT COUNT(*)
        FROM sales_order o
        <include refid="whereClause"/>
    </select>

</mapper>
