<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conk.order.query.mapper.OutboundStatsQueryMapper">

    <select id="countPendingOutboundOrdersByDate" resultType="int">
        SELECT COUNT(*)
        FROM sales_order
        WHERE status = 'RECEIVED'
          AND DATE(ordered_at) = #{date}
    </select>
</mapper>
